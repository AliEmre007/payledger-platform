#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
RUNTIME_DIR="$ROOT_DIR/.runtime"
COMPOSE_FILE="$ROOT_DIR/infra/compose/compose.yaml"

API_PORT="${API_PORT:-18080}"
FRONTEND_PORT="${FRONTEND_PORT:-5173}"
KEYCLOAK_HEALTH_URL="${KEYCLOAK_HEALTH_URL:-http://localhost:19000/health/ready}"
BACKEND_HEALTH_URL="${BACKEND_HEALTH_URL:-http://localhost:${API_PORT}/actuator/health}"
FRONTEND_URL="${FRONTEND_URL:-http://localhost:${FRONTEND_PORT}/}"

mkdir -p "$RUNTIME_DIR"

info() {
  printf '[startProject] %s\n' "$*"
}

fail() {
  printf '[startProject] ERROR: %s\n' "$*" >&2
  exit 1
}

command_exists() {
  command -v "$1" >/dev/null 2>&1
}

http_ok() {
  curl -fsS "$1" >/dev/null 2>&1
}

port_open() {
  local port="$1"

  if command_exists nc; then
    nc -z localhost "$port" >/dev/null 2>&1
    return
  fi

  curl -fsS "http://localhost:${port}/" >/dev/null 2>&1
}

wait_for_url() {
  local label="$1"
  local url="$2"
  local attempts="${3:-60}"
  local delay_seconds="${4:-2}"

  info "Waiting for ${label}..."
  for _ in $(seq 1 "$attempts"); do
    if http_ok "$url"; then
      info "${label} is ready."
      return 0
    fi
    sleep "$delay_seconds"
  done

  return 1
}

start_background() {
  local name="$1"
  local pid_file="$2"
  local log_file="$3"
  shift 3

  if [[ -f "$pid_file" ]]; then
    local existing_pid
    existing_pid="$(cat "$pid_file")"
    if [[ -n "$existing_pid" ]] && kill -0 "$existing_pid" >/dev/null 2>&1; then
      info "${name} is already running with PID ${existing_pid}."
      return 0
    fi
  fi

  info "Starting ${name}. Logs: ${log_file}"
  (
    cd "$ROOT_DIR"
    "$@"
  ) >"$log_file" 2>&1 &

  echo "$!" >"$pid_file"
  info "${name} PID: $(cat "$pid_file")"
}

ensure_requirements() {
  command_exists docker || fail "Docker is not installed or not on PATH."
  docker compose version >/dev/null 2>&1 || fail "Docker Compose is not available."
  command_exists curl || fail "curl is required for readiness checks."
  [[ -x "$ROOT_DIR/backend/mvnw" ]] || fail "backend/mvnw is missing or not executable."
  command_exists npm || fail "npm is not installed or not on PATH."
}

start_infra() {
  info "Starting local infrastructure with Docker Compose."
  docker compose -f "$COMPOSE_FILE" up -d
  wait_for_url "Keycloak" "$KEYCLOAK_HEALTH_URL" 90 2 || fail "Keycloak did not become healthy. Check Docker logs."
}

start_backend() {
  if http_ok "$BACKEND_HEALTH_URL"; then
    info "Backend is already healthy at ${BACKEND_HEALTH_URL}."
    return 0
  fi

  if port_open "$API_PORT"; then
    info "Port ${API_PORT} is already in use; assuming the backend is starting or running."
  else
    start_background \
      "backend API" \
      "$RUNTIME_DIR/backend.pid" \
      "$RUNTIME_DIR/backend.log" \
      "$ROOT_DIR/backend/mvnw" -f "$ROOT_DIR/backend/pom.xml" spring-boot:run
  fi

  wait_for_url "backend API" "$BACKEND_HEALTH_URL" 90 2 || fail "Backend did not become healthy. Check $RUNTIME_DIR/backend.log."
}

start_frontend() {
  if http_ok "$FRONTEND_URL"; then
    info "Frontend is already serving at ${FRONTEND_URL}."
    return 0
  fi

  if [[ ! -d "$ROOT_DIR/frontend/node_modules" ]]; then
    info "Installing frontend dependencies."
    (cd "$ROOT_DIR/frontend" && npm ci)
  fi

  if port_open "$FRONTEND_PORT"; then
    info "Port ${FRONTEND_PORT} is already in use; assuming the frontend is starting or running."
  else
    start_background \
      "frontend" \
      "$RUNTIME_DIR/frontend.pid" \
      "$RUNTIME_DIR/frontend.log" \
      npm --prefix "$ROOT_DIR/frontend" run dev
  fi

  wait_for_url "frontend" "$FRONTEND_URL" 60 2 || fail "Frontend did not become ready. Check $RUNTIME_DIR/frontend.log."
}

main() {
  ensure_requirements
  start_infra
  start_backend
  start_frontend

  info "PayLedger is running."
  info "Frontend: ${FRONTEND_URL}"
  info "Backend health: ${BACKEND_HEALTH_URL}"
  info "Keycloak: http://localhost:18081/"
  info "Logs: ${RUNTIME_DIR}"
}

main "$@"
