# Copy to an untracked .env file before running compose.prod.yaml.
# Do not commit real production secrets.

POSTGRES_DB=payledger
POSTGRES_USER=payledger_app
POSTGRES_PASSWORD=replace-with-generated-database-password

KEYCLOAK_ISSUER_URI=https://identity.example.com/realms/payledger
KEYCLOAK_AUDIENCE=payledger-api

PAYLEDGER_BACKEND_IMAGE=payledger-api:local
PAYLEDGER_BACKEND_PUBLISHED_PORT=18080

PAYLEDGER_MAX_REQUEST_BODY_BYTES=131072
PAYLEDGER_RATE_LIMIT_ENABLED=true
PAYLEDGER_RATE_LIMIT_WINDOW=PT1M
PAYLEDGER_RATE_LIMIT_MAX_REQUESTS=120
PAYLEDGER_MANAGEMENT_PROMETHEUS_PUBLIC=false

PROMETHEUS_PUBLISHED_PORT=19090

HTTPS_PUBLISHED_PORT=18443
TLS_CERTIFICATE_PATH=./nginx/dev-cert.pem
TLS_PRIVATE_KEY_PATH=./nginx/dev-key.pem
